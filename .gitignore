# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# blog image backups (local only)
public/images/blog/_backup/

# test scrap
test-cards-preview.html
test-results/
/playwright-report/

# font source packs (woff2 runtime files live alongside)
public/fonts/pp-neue-montreal-cufonfonts/

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
